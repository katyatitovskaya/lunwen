 *@

@using Try2.Models.DTOs
@model CommentDto

@{
    int? currentUserId = ViewBag.CurrentUserId as int?;
    bool isLiked = currentUserId != null &&
                   Model.Likes.Any(l => l.UserId == currentUserId);
    bool isAuthor = currentUserId == Model.AuthorId;
}

<div class="comment-card"
     style="border:1px solid #ddd; padding:10px; margin-top:10px">
    <a href="@Url.Action("Profile", "User", new { id = Model.AuthorId })">
    <div style="display:flex; align-items:flex-start; gap:10px">
        <!-- Аватар -->
        @if (!string.IsNullOrEmpty(Model.AuthorProfilePhoto))
        {
            <img src="@Model.AuthorProfilePhoto"
                 alt="Profile photo"
                 style="width:40px; height:40px; border-radius:50%; object-fit:cover;" />
        }
        else
        {
            <div style="width:40px; height:40px; border-radius:50%; background-color:#e0e0e0; display:flex; align-items:center; justify-content:center; font-size:20px; color:#666;">
                @(Model.AuthorNickname?.Substring(0, 1) ?? "?")
            </div>
        }

        <div style="flex:1">
            <!-- Информация об авторе и текст комментария -->
            <div>
                <strong>@Model.AuthorNickname</strong>
                <span style="color:gray">@Model.AuthorUsername</span>
            </div>
            </a>
            <p>@Html.Raw(Try2.Models.Services.TextFormatter.FormatPostText(Model.Text))</p>

            <small>@Model.PublicationTime.ToLocalTime()</small>
        </div>
    </div>

    <!-- Нижняя панель с действиями -->
    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px; padding-left:50px">
        <!-- Левая часть: текст Ответить | Удалить -->
        <div style="display:flex; gap:10px;">
            <span style="color:#0066cc; cursor:pointer;" onclick="event.stopPropagation(); toggleReply(@Model.Id)">Ответить</span>

            @if (isAuthor)
            {
                <form asp-controller="Posts"
                      asp-action="DeleteComment"
                      method="post"
                      style="display:inline; margin:0; padding:0;"
                      onsubmit="return confirm('Вы уверены, что хотите удалить комментарий?');">

                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <button type="submit"
                            style="background:none;
                       border:none;
                       color:#cc0000;
                       cursor:pointer;
                       padding:0;
                       margin:0;
                       font-family:inherit;
                       font-size:inherit;
                       text-decoration:none;
                       display:inline;">
                        Удалить
                    </button>
                </form>
               
            }
        </div>

        <!-- Правая часть: Лайк -->
        <div onclick="event.stopPropagation()">
            @if (!isLiked)
            {
                <form asp-controller="Comments"
                      asp-action="Like"
                      method="post"
                      style="display:inline;">
                    <input type="hidden" name="commentId" value="@Model.Id" />
                    <input type="hidden" name="postId" value="@ViewBag.PostId" />
                    <button type="submit">
                        ♡ @Model.Likes.Count
                    </button>
                </form>
            }
            else
            {
                <form asp-controller="Comments"
                      asp-action="Unlike"
                      method="post"
                      style="display:inline;">
                    <input type="hidden" name="commentId" value="@Model.Id" />
                    <input type="hidden" name="postId" value="@ViewBag.PostId" />
                    <button type="submit" >
                        ❤️ @Model.Likes.Count
                    </button>
                </form>
            }
        </div>
    </div>

    <!-- Форма ответа -->
    <form asp-controller="Comments"
          asp-action="Reply"
          method="post"
          id="reply-@Model.Id"
          class="reply-form"
          onclick="event.stopPropagation()"
          style="display:none; margin-top:10px; padding-left:50px">

        <input type="hidden" name="postId" value="@ViewBag.PostId" />
        <input type="hidden" name="parentCommentId" value="@Model.Id" />

        <textarea name="text" rows="2" style="width:100%; margin-bottom:5px;" placeholder="Напишите ответ..."></textarea>
        <button type="submit">Отправить</button>
    </form>

    <!-- Рекурсия для ответов -->
    @if (Model.Replies?.Any() == true)
    {
        <div style="margin-left:30px; margin-top:10px">
            @foreach (var reply in Model.Replies)
            {
                @await Html.PartialAsync("_Comment", reply)
            }
        </div>
    }
</div>