@{
    ViewData["Title"] = "Поиск";
}

<div class="search-container">
    <h2>Поиск</h2>

    <div class="search-controls">
        <div class="search-row">
            <!-- Поле поиска по тексту -->
            <div class="search-input-wrapper">
                <input type="text"
                       id="searchQuery"
                       class="search-input"
                       placeholder="Поиск по тексту..."
                       autocomplete="off" />
            </div>

            <!-- ОБЪЕДИНЕННОЕ ПОЛЕ: поиск тега + отображение выбранного -->
            <div class="tag-input-wrapper">
                <input type="text"
                       id="tagSearchInput"
                       class="search-input"
                       placeholder="Поиск тега..."
                       autocomplete="off" />
                <div id="tagSuggestions" class="tag-suggestions-dropdown"></div>
            </div>

            <!-- Тип поиска -->
            <select id="searchType" class="search-select">
                <option value="All">Все</option>
                <option value="Posts">Посты</option>
                <option value="Users">Люди</option>
            </select>

            <!-- Фильтр фазы -->
            <select id="phaseFilter" class="search-select" disabled>
                <option value="">Все фазы</option>
                <option value="0">📚 Интересуюсь</option>
                <option value="1">🎓 Изучаю</option>
                <option value="2">👨‍🏫 Преподаю</option>
            </select>
        </div>
    </div>

    <hr />

    <div id="searchResults">
        <div class="text-center text-muted py-5">
            Введите запрос или выберите тег для поиска
        </div>
    </div>
</div>
<style>
    .search-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 20px;
    }

    .search-controls {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 8px;
    }

    .search-row {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-input-wrapper {
        flex: 1;
        min-width: 100%;
    }

    .tag-input-wrapper {
        flex: 2;
        min-width: 220px;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #FFB74D;
        border-radius: 4px;
        font-size: 0.95rem;
        background: white;
        margin: 0 !important;
    }

        .search-input:focus {
            outline: none;
            border-color: #4CAF50;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.2);
        }

    .search-select {
        flex: 1;
        min-width: 130px;
        padding: 10px 12px;
        border: 1px solid #FFB74D;
        border-radius: 4px;
        background: white;
        margin: 0 !important;
    }

    .selected-tag-display {
        flex: 1.5;
        min-width: 180px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 12px;
        background: white;
        border: 1px solid #FFB74D;
        border-radius: 4px;
    }

    .tag-suggestions-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        max-height: 300px;
        overflow-y: auto;
        z-index: 9999;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        display: none;
        margin-top: 2px;
    }

    .tag-suggestion-item {
        padding: 10px 15px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #f0f0f0;
    }

        .tag-suggestion-item:hover {
            background-color: #e7f1ff;
        }

    .btn-remove-tag {
        background: none !important;
        border: none !important;
        color: #dc3545 !important;
        cursor: pointer;
        font-size: 18px;
        padding: 0 5px !important;
        box-shadow: none !important;
    }

        .btn-remove-tag:hover {
            color: #c82333 !important;
            transform: none !important;
        }

    /* Результаты */
    .users-results {
        margin-bottom: 20px;
    }

    .user-card {
        display: flex;
        align-items: center;
        padding: 12px;
        background: white;
        border: 1px solid #FFCC80;
        border-radius: 8px;
        margin-bottom: 8px;
    }

    .user-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        margin-right: 15px;
        background: #FFE0B2;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #E65100;
    }

        .user-avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
        }

    .user-info {
        flex: 1;
    }

    .user-nickname {
        font-weight: 600;
        color: #E65100;
    }

        .user-nickname a {
            color: #E65100;
            text-decoration: none;
        }

            .user-nickname a:hover {
                text-decoration: underline;
            }

    .user-username {
        color: #4CAF50;
        font-size: 0.9rem;
    }

    .user-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-top: 4px;
    }

    .mini-tag {
        background: #f0f0f0;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.75rem;
        color: #666;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 12px;
        color: #E65100;
    }

    .spinner-border {
        display: inline-block;
        width: 2rem;
        height: 2rem;
        border: 0.25em solid #4CAF50;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spinner-border 0.75s linear infinite;
    }

    @@keyframes spinner-border {
        to {
            transform: rotate(360deg);
        }
    }

    .post-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

    .post-card {
        background-color: white;
        border: 1px solid #FFCC80;
        border-radius: 6px;
        padding: 12px;
        margin-bottom: 12px;
        transition: all 0.2s ease;
    }

        .post-card:hover {
            border-color: #4CAF50;
            transform: translateY(-2px);
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.1);
        }

    .post-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .post-author {
        color: #E65100;
        font-size: 0.95rem;
    }

    .post-username {
        color: #4CAF50;
        font-size: 0.85rem;
    }

    .post-text {
        color: #5D4037;
        font-size: 0.9rem;
        line-height: 1.4;
        margin-bottom: 10px;
    }

    .post-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
    }

    .follow-btn {
        padding: 6px 16px;
        font-size: 0.85rem;
    }
</style>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            let selectedTagId = null;
            let selectedTagName = null;
            let searchTimeout;
            let tagSearchTimeout;
            let currentSearchType = 'All';

            const searchQuery = document.getElementById('searchQuery');
            const tagSearchInput = document.getElementById('tagSearchInput');
            const searchType = document.getElementById('searchType');
            const phaseFilter = document.getElementById('phaseFilter');
            const tagSuggestions = document.getElementById('tagSuggestions');
            const resultsDiv = document.getElementById('searchResults');

            // Управление видимостью фильтра фазы
            function updatePhaseFilterVisibility() {
                if (currentSearchType === 'Posts') {
                    phaseFilter.disabled = true;
                    phaseFilter.value = '';
                } else {
                    phaseFilter.disabled = false;
                }
            }

            searchType.addEventListener('change', function() {
                currentSearchType = this.value;
                updatePhaseFilterVisibility();
                performSearch();
            });

            updatePhaseFilterVisibility();
            phaseFilter.addEventListener('change', performSearch);

            // Живой поиск по тексту
            searchQuery.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(performSearch, 300);
            });

            // Поиск тегов при вводе
            tagSearchInput.addEventListener('input', function() {
                clearTimeout(tagSearchTimeout);
                const term = this.value.trim();

                if (term.length < 1) {
                    tagSuggestions.style.display = 'none';
                    return;
                }

                tagSearchTimeout = setTimeout(function() { searchTags(term); }, 300);
            });

            // Закрытие подсказок при клике вне
            document.addEventListener('click', function(e) {
                if (!tagSearchInput.contains(e.target) && !tagSuggestions.contains(e.target)) {
                    tagSuggestions.style.display = 'none';
                }
            });

            // Очистка выбранного тега при ручном вводе
            tagSearchInput.addEventListener('input', function() {
                if (selectedTagId) {
                    selectedTagId = null;
                    selectedTagName = null;
                }
            });

            async function searchTags(term) {
                try {
                    console.log('Поиск тегов:', term);
                    const response = await fetch('/api/searchapi/tags?term=' + encodeURIComponent(term));
                    const tags = await response.json();
                    console.log('Найдено тегов:', tags.length);
                    if (tags.length > 0) {
                        displayTagSuggestions(tags);
                    } else {
                        tagSuggestions.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Ошибка поиска тегов:', error);
                }
            }

            function displayTagSuggestions(tags) {
                let html = '';
                tags.forEach(function(tag) {
                    html += '<div class="tag-suggestion-item" onclick="selectTag(' + tag.id + ', \'' + tag.name.replace(/'/g, "\\'") + '\')">' +
                        '<span>' + tag.name + '</span>' +
                        '<span style="color:#6c757d;font-size:0.85em;">' + tag.usageCount + ' исп.</span>' +
                    '</div>';
                });
                tagSuggestions.innerHTML = html;
                tagSuggestions.style.display = 'block';
            }

            window.selectTag = function(tagId, tagName) {
                console.log('Выбран тег:', tagId, tagName);
                selectedTagId = tagId;
                selectedTagName = tagName;
                tagSearchInput.value = tagName; // Показываем выбранный тег в поле
                tagSuggestions.style.display = 'none';
                performSearch(); // Сразу ищем
            };

            async function performSearch() {
                const query = searchQuery.value.trim();

                // Формируем параметры
                let params = 'query=' + encodeURIComponent(query) +
                             '&searchType=' + currentSearchType;

                if (currentSearchType !== 'Posts') {
                    params += '&phase=' + (phaseFilter.value || '');
                }

                // Добавляем tagId если тег выбран (из selectedTagId, а не из поля)
                if (selectedTagId) {
                    params += '&tagId=' + selectedTagId;
                }

                console.log('Параметры поиска:', params);

                // Не ищем если нет ни запроса, ни тега
                if (!query && !selectedTagId) {
                    resultsDiv.innerHTML = '<div class="text-center text-muted py-5">Введите запрос или выберите тег для поиска</div>';
                    return;
                }

                resultsDiv.innerHTML = '<div class="text-center py-5"><div class="spinner-border"></div></div>';

                try {
                    const response = await fetch('/api/searchapi?' + params);
                    const data = await response.json();
                    console.log('Результаты поиска:', data);
                    displayResults(data);
                } catch (error) {
                    console.error('Ошибка поиска:', error);
                    resultsDiv.innerHTML = '<div class="alert alert-danger">Ошибка при выполнении поиска</div>';
                }
            }

            function displayResults(data) {
                let html = '';

                // Пользователи
                if (data.users && data.users.length > 0) {
                    html += '<div class="users-results">';
                    html += '<div class="section-title">👥 Пользователи (' + data.users.length + ')</div>';

                    data.users.forEach(function(user) {
                        html += '<div class="user-card">' +
                            '<a href="/User/Profile/' + user.id + '" style="display:contents;">' +
                                '<div class="user-avatar">' +
                                    (user.profilePhotoPath
                                        ? '<img src="' + user.profilePhotoPath + '" alt="' + user.nickname + '" />'
                                        : user.nickname.charAt(0).toUpperCase()) +
                                '</div>' +
                            '</a>' +
                            '<div class="user-info">' +
                                '<div class="user-nickname">' +
                                    '<a href="/User/Profile/' + user.id + '">' + user.nickname + '</a>' +
                                '</div>' +
                                '<div class="user-username">@@' + user.username + '</div>';

                        if (user.tags && user.tags.length > 0) {
                            html += '<div class="user-tags">';
                            user.tags.slice(0, 5).forEach(function(t) {
                                html += '<span class="mini-tag">' + t.tagName + ' (' + getPhaseShort(t.phase) + ')</span>';
                            });
                            html += '</div>';
                        }

                        html += '</div>' +
                            '<div>' +
                                '<button class="btn follow-btn ' + (user.isFollowedByCurrentUser ? 'btn-outline-secondary' : 'btn-primary') + '" ' +
                                    'onclick="toggleFollow(' + user.id + ', this)">' +
                                    (user.isFollowedByCurrentUser ? 'Отписаться' : 'Подписаться') +
                                '</button>' +
                            '</div>' +
                        '</div>';
                    });

                    html += '</div>';
                }

                // Посты
                if (data.posts && data.posts.length > 0) {
                    html += '<div class="posts-results">';
                    html += '<div class="section-title">📝 Посты (' + data.posts.length + ')</div>';

                    data.posts.forEach(function(post) {
                        html += '<a href="/Posts/Details/' + post.id + '" class="post-link">' +
                            '<div class="post-card">' +
                                '<a href="/User/Profile/' + post.authorId + '" onclick="event.stopPropagation();">' +
                                    '<div class="post-header">' +
                                        (post.authorProfilePhoto
                                            ? '<img src="' + post.authorProfilePhoto + '" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />'
                                            : '<div style="width:40px;height:40px;border-radius:50%;background:#FFE0B2;display:flex;align-items:center;justify-content:center;color:#E65100;">' + post.authorNickname.charAt(0).toUpperCase() + '</div>') +
                                        '<div>' +
                                            '<strong class="post-author">' + post.authorNickname + '</strong>' +
                                            '<span class="post-username">@@' + post.authorUsername + '</span>' +
                                        '</div>' +
                                    '</div>' +
                                '</a>' +
                                '<div class="post-text">' + escapeHtml(post.text) + '</div>';

                        if (post.tags && post.tags.length > 0) {
                            html += '<div class="user-tags" style="margin-bottom:8px;">';
                            post.tags.forEach(function(t) {
                                html += '<span class="mini-tag">#' + t.tagName + '</span>';
                            });
                            html += '</div>';
                        }

                        html += '<div class="post-footer">' +
                                    '❤️ ' + post.likesCount +
                                    '<span>' + new Date(post.publicationDate).toLocaleDateString() + '</span>' +
                                '</div>' +
                            '</div>' +
                        '</a>';
                    });

                    html += '</div>';
                }

                if ((!data.users || data.users.length === 0) && (!data.posts || data.posts.length === 0)) {
                    html = '<div class="text-center text-muted py-5">Ничего не найдено</div>';
                }

                resultsDiv.innerHTML = html;
            }

            function getPhaseShort(phase) {
                const phases = ['📚', '🎓', '👨‍🏫'];
                return phases[phase] || '';
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            window.toggleFollow = async function(userId, btn) {
                const isFollowed = btn.textContent.includes('Отписаться');
                const url = isFollowed ? '/User/Unfollow' : '/User/Follow';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'userId=' + userId
                    });

                    if (response.ok) {
                        btn.textContent = isFollowed ? 'Подписаться' : 'Отписаться';
                        btn.classList.toggle('btn-primary');
                        btn.classList.toggle('btn-outline-secondary');
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                }
            };
        });
    </script>
}

