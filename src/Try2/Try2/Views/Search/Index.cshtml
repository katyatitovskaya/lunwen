            let selectedTagName = null;
            let searchTimeout;
            let searchDebounce;
            let currentSearchType = 'All';

            const searchQuery = document.getElementById('searchQuery');
            const searchType = document.getElementById('searchType');
            const phaseFilter = document.getElementById('phaseFilter');
            const tagSuggestions = document.getElementById('tagSuggestions');
            const selectedTagDisplay = document.getElementById('selectedTagDisplay');
            const clearTagBtn = document.getElementById('clearTagBtn');
            const resultsDiv = document.getElementById('searchResults');

            // Переключение видимости фильтра фазы
            searchType.addEventListener('change', function() {
                currentSearchType = this.value;
                phaseFilter.disabled = this.value === 'Posts';
                if (this.value === 'Posts') {
                    phaseFilter.value = '';
                }
                performSearch();
            });

            phaseFilter.addEventListener('change', performSearch);

            // Поиск тегов при вводе
            searchQuery.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                const term = this.value.trim();

                if (term.length < 1) {
                    tagSuggestions.style.display = 'none';
                    if (!selectedTagId) {
                        performSearch();
                    }
                    return;
                }

                if (!selectedTagId) {
                    searchTimeout = setTimeout(function() { searchTags(term); }, 300);
                }
            });

            document.addEventListener('click', function(e) {
                if (!searchQuery.contains(e.target) && !tagSuggestions.contains(e.target)) {
                    tagSuggestions.style.display = 'none';
                }
            });

            async function searchTags(term) {
                try {
                    const response = await fetch('/api/searchapi/tags?term=' + encodeURIComponent(term));
                    const tags = await response.json();
                    if (tags.length > 0) {
                        displayTagSuggestions(tags);
                    } else {
                        tagSuggestions.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Ошибка поиска тегов:', error);
                }
            }

            function displayTagSuggestions(tags) {
                let html = '';
                tags.forEach(function(tag) {
                    html += '<div class="tag-suggestion-item" onclick="selectTag(' + tag.id + ', \'' + tag.name.replace(/'/g, "\\'") + '\')">' +
                        '<span>#' + tag.name + '</span>' +
                        '<span style="color:#6c757d;font-size:0.85em;">' + tag.usageCount + ' исп.</span>' +
                    '</div>';
                });
                tagSuggestions.innerHTML = html;
                tagSuggestions.style.display = 'block';
            }

            window.selectTag = function(tagId, tagName) {
                selectedTagId = tagId;
                selectedTagName = tagName;
                searchQuery.value = tagName;
                updateSelectedTagDisplay();
                tagSuggestions.style.display = 'none';
                performSearch();
            };

            window.clearTag = function() {
                selectedTagId = null;
                selectedTagName = null;
                searchQuery.value = '';
                updateSelectedTagDisplay();
                performSearch();
            };

            function updateSelectedTagDisplay() {
                if (selectedTagId) {
                    selectedTagDisplay.innerHTML = '<span><strong>#' + selectedTagName + '</strong></span>' +
                        '<button type="button" class="btn-remove-tag" onclick="clearTag()">✕</button>';
                } else {
                    selectedTagDisplay.innerHTML = '<span class="text-muted">Тег не выбран</span>' +
                        '<button type="button" class="btn-remove-tag" id="clearTagBtn" style="display:none;">✕</button>';
                }
            }

            if (clearTagBtn) {
                clearTagBtn.addEventListener('click', clearTag);
            }

            async function performSearch() {
                const query = selectedTagId ? '' : searchQuery.value.trim();
                
                if (!query && !selectedTagId) {
                    resultsDiv.innerHTML = '<div class="text-center text-muted py-5">Введите запрос или выберите тег для поиска</div>';
                    return;
                }

                resultsDiv.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>';

                let params = 'query=' + encodeURIComponent(query) + 
                             '&searchType=' + currentSearchType + 
                             '&phase=' + (phaseFilter.value || '');

                if (selectedTagId) {
                    params += '&tagId=' + selectedTagId;
                }

                try {
                    const response = await fetch('/api/searchapi?' + params);
                    const data = await response.json();
                    displayResults(data);
                } catch (error) {
                    console.error('Ошибка поиска:', error);
                    resultsDiv.innerHTML = '<div class="alert alert-danger">Ошибка при выполнении поиска</div>';
                }
            }

            function displayResults(data) {
                let html = '';

                // Пользователи
                if (data.users && data.users.length > 0) {
                    html += '<div class="users-results">';
                    html += '<div class="section-title">👥 Пользователи (' + data.users.length + ')</div>';
                    
                    data.users.forEach(function(user) {
                        html += '<div class="user-card">' +
                            '<div class="user-avatar">' +
                                (user.profilePhotoPath 
                                    ? '<img src="' + user.profilePhotoPath + '" alt="' + user.nickname + '" />' 
                                    : user.nickname.charAt(0).toUpperCase()) +
                            '</div>' +
                            '<div class="user-info">' +
                                '<div class="user-nickname">' + user.nickname + '</div>' +
                                '<div class="user-username">@@' + user.username + '</div>';
                        
                        if (user.tags && user.tags.length > 0) {
                            html += '<div class="user-tags">';
                            user.tags.slice(0, 5).forEach(function(t) {
                                html += '<span class="mini-tag">' + t.tagName + ' (' + getPhaseShort(t.phase) + ')</span>';
                            });
                            if (user.tags.length > 5) {
                                html += '<span class="mini-tag">+' + (user.tags.length - 5) + '</span>';
                            }
                            html += '</div>';
                        }
                        
                        html += '</div>' +
                            '<div>' +
                                '<button class="btn follow-btn ' + (user.isFollowedByCurrentUser ? 'btn-outline-secondary' : 'btn-primary') + '" ' +
                                    'onclick="toggleFollow(' + user.id + ', this)">' +
                                    (user.isFollowedByCurrentUser ? 'Отписаться' : 'Подписаться') +
                                '</button>' +
                            '</div>' +
                        '</div>';
                    });
                    
                    html += '</div>';
                }

                // Посты
                if (data.posts && data.posts.length > 0) {
                    html += '<div class="posts-results">';
                    html += '<div class="section-title">📝 Посты (' + data.posts.length + ')</div>';
                    
                    data.posts.forEach(function(post) {
                        html += '<div class="post-card">' +
                            '<div class="post-header">' +
                                '<div class="post-avatar">' +
                                    (post.authorProfilePhoto 
                                        ? '<img src="' + post.authorProfilePhoto + '" alt="' + post.authorNickname + '" />' 
                                        : post.authorNickname.charAt(0).toUpperCase()) +
                                '</div>' +
                                '<div>' +
                                    '<div class="post-author">' + post.authorNickname + '</div>' +
                                    '<div class="post-time">@@' + post.authorUsername + ' · ' + new Date(post.publicationDate).toLocaleDateString() + '</div>' +
                                '</div>' +
                            '</div>' +
                            '<div class="post-text">' + escapeHtml(post.text) + '</div>';
                        
                        if (post.tags && post.tags.length > 0) {
                            html += '<div class="post-tags">';
                            post.tags.forEach(function(t) {
                                html += '<span class="mini-tag">#' + t.tagName + '</span>';
                            });
                            html += '</div>';
                        }
                        
                        html += '<div class="post-footer">' +
                                '<button class="like-btn" onclick="togglePostLike(' + post.id + ', this)">' +
                                    (post.isLikedByCurrentUser ? '❤️' : '♡') + ' ' + post.likesCount +
                                '</button>' +
                                '<a href="/Posts/Details/' + post.id + '" class="text-muted">Подробнее →</a>' +
                            '</div>' +
                        '</div>';
                    });
                    
                    html += '</div>';
                }

                if ((!data.users || data.users.length === 0) && (!data.posts || data.posts.length === 0)) {
                    html = '<div class="text-center text-muted py-5">Ничего не найдено</div>';
                }

                resultsDiv.innerHTML = html;
            }

            function getPhaseShort(phase) {
                const phases = ['📚', '🎓', '👨‍🏫'];
                return phases[phase] || '';
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            window.toggleFollow = async function(userId, btn) {
                const isFollowed = btn.textContent.includes('Отписаться');
                const url = isFollowed ? '/User/Unfollow' : '/User/Follow';
                
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'userId=' + userId
                    });
                    
                    if (response.ok) {
                        btn.textContent = isFollowed ? 'Подписаться' : 'Отписаться';
                        btn.classList.toggle('btn-primary');
                        btn.classList.toggle('btn-outline-secondary');
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                }
            };

            window.togglePostLike = async function(postId, btn) {
                const isLiked = btn.innerHTML.includes('❤️');
                const url = isLiked ? '/Posts/Unlike' : '/Posts/Like';
                
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'postId=' + postId
                    });
                    
                    if (response.ok) {
                        const match = btn.innerHTML.match(/\d+/);
                        const count = match ? parseInt(match[0]) : 0;
                        btn.innerHTML = isLiked ? '♡ ' + (count - 1) : '❤️ ' + (count + 1);
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                }
            };

            // Живой поиск при вводе
            searchQuery.addEventListener('input', function() {
                if (!selectedTagId) {
                    clearTimeout(searchDebounce);
                    searchDebounce = setTimeout(performSearch, 300);
                }
            });

            // Инициализация
            updateSelectedTagDisplay();
        });
    </script>
} *@