@model Try2.Models.DTOs.UserProfileDto
@using Try2.Models.Enums;

<div class="profile-container">
    <div class="profile-header">
        @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
        {
            <img src="@Model.ProfilePhotoPath"
                 class="avatar"
                 style="width:120px; height:120px; border-radius:50%" />
        }
        else
        {
            <div class="avatar">👤</div>
        }

        <div class="info">
            <h2>@Model.Nickname</h2>
            <a asp-controller="User" asp-action="Profile">@Model.Username</a>
            <p>@Model.Role</p>
            
            @{
                var interestedTags = Model.UserTags.Where(t => t.Phase == TagStudyPhase.Interested).ToList();
                var studyingTags = Model.UserTags.Where(t => t.Phase == TagStudyPhase.Studying).ToList();
                var teachingTags = Model.UserTags.Where(t => t.Phase == TagStudyPhase.Teaching).ToList();
            }

            <div class="user-tags-profile">
                @if (interestedTags.Any())
                {
                    <div class="tag-phase-group">
                        <span class="phase-label">Интересуюсь: </span>
                        <div class="phase-tags">
                            @foreach (var tag in interestedTags)
                            {
                                <span class="profile-tag">
                                    @tag.TagName
                                    <span class="tag-year">с @tag.StudyStartYear</span>
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (studyingTags.Any())
                {
                    <div class="tag-phase-group">
                        <span class="phase-label">Изучаю: </span>
                        <div class="phase-tags">
                            @foreach (var tag in studyingTags)
                            {
                                <span class="profile-tag">
                                    @tag.TagName
                                    <span class="tag-year">с @tag.StudyStartYear</span>
                                    @if (!tag.IsConfirmed)
                                    {
                                        <span class="pending-badge" title="Ожидает подтверждения">⏳</span>
                                    }
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (teachingTags.Any())
                {
                    <div class="tag-phase-group">
                        <span class="phase-label">Преподаю: </span>
                        <div class="phase-tags">
                            @foreach (var tag in teachingTags)
                            {
                                <span class="profile-tag">
                                    @tag.TagName
                                    <span class="tag-year">с @tag.StudyStartYear</span>
                                    @if (!tag.IsConfirmed)
                                    {
                                        <span class="pending-badge" title="Ожидает подтверждения">⏳</span>
                                    }
                                </span>
                            }
                        </div>
                    </div>
                }

                @if (!Model.UserTags.Any())
                {
                    <p class="no-tags-message">Теги не указаны</p>
                }
            </div>
            <div class="bio-section">
                <h6>Био</h6>
                <p>@Html.Raw(Try2.Models.Services.TextFormatter.FormatPostText(Model.Bio))</p>
            </div>
            

            <div class="stats">
                <span>Подписчики: @Model.FollowersCount</span>
                <span>Подписки: @Model.FollowingCount</span>
            </div>

            @if (!Model.IsCurrentUser)
            {
                <form method="post" class="follow-form"
                      asp-action="@(Model.IsFollowedByCurrentUser ? "Unfollow" : "Follow")"
                      asp-route-userId="@Model.Id">
                    <button class="follow-btn" type="submit">
                        @(Model.IsFollowedByCurrentUser ? "Отписаться" : "Подписаться")
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="User" asp-action="Edit">Изменить профиль</a>
                <a asp-controller="Posts" asp-action="Create">Написать пост</a>
            }
        </div>
    </div>

    <hr />

    <div class="posts">
        @foreach (var post in Model.Posts)
        {
            <a asp-controller="Posts"
               asp-action="Details"
               asp-route-id="@post.Id"
               class="post-link">

                <div class="post-card">
                    <div class="post-header">

                        <!-- Фото пользователя -->
                        @if (!string.IsNullOrEmpty(Model.ProfilePhotoPath))
                        {
                                <img src="@Model.ProfilePhotoPath"
                                     style="width:40px; height:40px; border-radius:50%; object-fit:cover;" />
                        }
                        else
                        {
                            <!-- Заглушка, если фото нет -->
                            <div style="width:40px; height:40px; border-radius:50%; background-color:#e0e0e0; display:flex; align-items:center; justify-content:center; font-size:20px; color:#666;">
                                @(post.AuthorNickname?.Substring(0, 1) ?? "?")
                            </div>
                        }

                        <!-- Информация об авторе -->
                        <div>
                            <strong>@Model.Nickname</strong>
                            <span class="username">@Model.Username</span>
                        </div>
                    </div>
                    <div class="post-text">
                        @Html.Raw(Try2.Models.Services.TextFormatter.FormatPostText(post.Text))
                    </div>

                    <div class="post-footer">
                        ❤️ @post.LikesCount
                        <span class="date">@post.PublicationDate.ToShortDateString()</span>
                    </div>
                </div>
            </a>
        }
    </div>
</div>
