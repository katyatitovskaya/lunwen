@using Try2.Models.DTOs
@model FeedDto

<h2>Понравившиеся Вам посты</h2>

<hr />


<div class="post-section">
    @if(Model.LikedPosts == null || Model.LikedPosts.Count == 0)
    {
        <p>Похоже, что Вам пока ничего не понравилось</p>
    }
    else
    {
        @foreach (var post in Model.LikedPosts)
        {
            <a asp-controller="Posts"
               asp-action="Details"
               asp-route-id="@post.Id"
               class="post-link">

                <div class="post-card">
                    <a href="@Url.Action("Profile", "User", new { id = post.AuthorId })">
                        <div class="post-header">

                            <!-- Фото пользователя -->
                            @if (!string.IsNullOrEmpty(post.AuthorProfilePhoto))
                            {
                                <img src="@post.AuthorProfilePhoto"
                                     alt="Profile photo"
                                     style="width:40px; height:40px; border-radius:50%; object-fit:cover;" />
                            }
                            else
                            {
                                <!-- Заглушка, если фото нет -->
                                <div style="width:40px; height:40px; border-radius:50%; background-color:#e0e0e0; display:flex; align-items:center; justify-content:center; font-size:20px; color:#666;">
                                    @(post.AuthorNickname?.Substring(0, 1) ?? "?")
                                </div>
                            }

                            <!-- Информация об авторе -->
                            <div>
                                <strong>@post.AuthorNickname</strong>
                                <span class="username">@post.AuthorUsername</span>
                            </div>

                        </div>
                    </a>

                    <div class="post-text">

                        <a asp-controller="Posts"
                           asp-action="Details"
                           asp-route-id="@post.Id"
                           style="text-decoration:none; color:inherit;">
                            <p> @Html.Raw(Try2.Models.Services.TextFormatter.FormatPostText(post.Text))</p>
                        </a>
                    </div>

                    <div class="post-footer">
                        ❤️ @post.LikesCount
                        <span class="date">@post.PublicationDate.ToShortDateString()</span>
                    </div>
                </div>

            </a>
        }
    }
    

</div>
