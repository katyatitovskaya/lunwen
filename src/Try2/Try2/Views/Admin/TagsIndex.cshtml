@model IEnumerable<Try2.Models.DTOs.TagDto>

@{
    ViewData["Title"] = "Управление тегами";
}

<h2>Управление тегами</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Использований</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var tag in Model)
        {
            <tr style="background-color: @(tag.IsConfirmed ? "#d4edda" : "#fff3cd")">
                <td>@tag.Id</td>
                <td>@tag.Name</td>
                <td>@tag.TotalUsage</td>
                <td>
                    @(tag.IsConfirmed ? "✓ Подтвержден" : "⏳ Ожидает")
                </td>
                <td>
                    @if (!tag.IsConfirmed)
                    {
                        <form asp-controller="Admin"
                              asp-action="ConfirmTag"
                              method="post"
                              style="display: inline;" class="form-as-a-button">
                            <input type="hidden" name="id" value="@tag.Id" />
                            <button type="submit" class="btn btn-success btn-sm">
                                Подтвердить
                            </button>
                        </form>
                    }
                    <a asp-controller="Admin"
                       asp-action="DeleteTag"
                       asp-route-id="@tag.Id"
                       class="btn btn-danger btn-sm">
                        Удалить
                    </a>

                    @if (!tag.IsConfirmed)
                    {
                        <a asp-controller="Admin"
                           asp-action="EditTag"
                           asp-route-id="@tag.Id"
                           class="btn btn-primary btn-sm">
                            Редактировать
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="alert alert-info">Теги не найдены</p>
}