@model Try2.Models.DTOs.RegisterDto

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card mt-5">
            <div class="card-header">
                <h3 class="text-center">Регистрация нового аккаунта</h3>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post" id="registerForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Username" class="form-label">Имя пользователя *</label>
                            <input asp-for="Username" class="form-control"
                                   id="usernameInput" minlength="3" required
                                   pattern="[A-Za-z0-9_]+"
                                   title="Только буквы английского алфавита и символ подчеркивания" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                            <div class="form-text" id="usernameHelp">
                                Минимум 3 символа. 
                            </div>
                            <div class="invalid-feedback" id="usernameError" style="display:none;">
                                Имя пользователя может содержать только буквы английского алфавита, цифры и символ подчеркивания
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Nickname" class="form-label">Отображаемое имя</label>
                            <input asp-for="Nickname" class="form-control" />
                            <span asp-validation-for="Nickname" class="text-danger"></span>
                            <div class="form-text">Как вас будут видеть другие пользователи</div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Пароль *</label>
                        <input asp-for="Password" type="password" class="form-control"
                               id="passwordInput" minlength="6" required />
                        <span asp-validation-for="Password" class="text-danger"></span>
                        <div class="form-text">Минимум 6 символов</div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Role" class="form-label">Роль *</label>
                        <select asp-for="Role" class="form-select"
                                asp-items="Html.GetEnumSelectList<Try2.Models.Enums.UserRole>()" required>
                            <option value="">Выберите роль</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                        <div class="form-text">Выберите роль для доступа к функционалу системы</div>
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <button type="submit" class="btn btn-success"
                                id="submitButton">
                            Зарегистрироваться
                        </button>
                    </div>

                    <div class="text-center">
                        <p>Уже есть аккаунт? <a asp-action="Login">Войти</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('registerForm');
            const submitButton = document.getElementById('submitButton');
            const usernameInput = document.getElementById('usernameInput');
            const passwordInput = document.getElementById('passwordInput');
            const roleSelect = document.querySelector('select[name="Role"]');
            const usernameError = document.getElementById('usernameError');
            const usernameHelp = document.getElementById('usernameHelp');

            // Функция для проверки username (только английские буквы и _)
            function isValidUsername(username) {
                const usernameRegex = /^[A-Za-z0-9_]+$/;
                return usernameRegex.test(username);
            }

            // Валидация username в реальном времени
            usernameInput.addEventListener('input', function() {
                const username = this.value;

                // Проверка на недопустимые символы
                if (username.length > 0 && !isValidUsername(username)) {
                    this.classList.add('is-invalid');
                    usernameError.style.display = 'block';
                    usernameHelp.style.color = '#dc3545';

                    // Удаляем недопустимые символы
                    const validUsername = username.replace(/[^A-Za-z0-9_]/g, '');
                    if (validUsername !== username) {
                        this.value = validUsername;
                    }
                } else {
                    if (username.length > 1) {
                        this.classList.remove('is-invalid');
                        usernameError.style.display = 'none';
                        usernameHelp.style.color = '';
                    } else if (username.length > 0) {
                        this.classList.add('is-invalid');
                        usernameError.style.display = 'none';
                        usernameHelp.style.color = '#dc3545';
                    } else {
                        this.classList.remove('is-invalid');
                        usernameError.style.display = 'none';
                        usernameHelp.style.color = '';
                    }
                }
            });

            // Блокировка ввода недопустимых символов
            usernameInput.addEventListener('keydown', function(e) {
                const key = e.key;
                const allowedKeys = ['Backspace', 'Delete', 'ArrowLeft', 'ArrowRight', 'ArrowUp', 'ArrowDown', 'Tab', 'Home', 'End'];

                if (allowedKeys.includes(key)) {
                    return; // Разрешаем служебные клавиши
                }

                // Проверяем, является ли вводимый символ допустимым
                if (!/^[A-Za-z0-9_]$/.test(key) && !e.ctrlKey && !e.metaKey) {
                    e.preventDefault();

                    // Показываем временное сообщение об ошибке
                    usernameInput.classList.add('is-invalid');
                    usernameError.style.display = 'block';

                    setTimeout(() => {
                        usernameError.style.display = 'none';
                    }, 2000);
                }
            });

            // Предотвращаем вставку недопустимых символов
            usernameInput.addEventListener('paste', function(e) {
                e.preventDefault();
                const pastedText = e.clipboardData.getData('text');
                const validText = pastedText.replace(/[^A-Za-z0-9_]/g, '');

                const start = this.selectionStart;
                const end = this.selectionEnd;
                const currentValue = this.value;
                const newValue = currentValue.substring(0, start) + validText + currentValue.substring(end);

                this.value = newValue;

                // Устанавливаем курсор в конец вставленного текста
                this.setSelectionRange(start + validText.length, start + validText.length);

                // Триггерим событие input для валидации
                this.dispatchEvent(new Event('input'));
            });

            // Показать/скрыть пароль
            function addPasswordToggle(inputElement) {
                const toggle = document.createElement('span');
                toggle.innerHTML = '👁️';
                toggle.style.cursor = 'pointer';
                toggle.style.position = 'absolute';
                toggle.style.right = '10px';
                toggle.style.top = '50%';
                toggle.style.transform = 'translateY(-50%)';
                toggle.style.zIndex = '10';

                const container = inputElement.parentElement;
                container.style.position = 'relative';
                container.appendChild(toggle);

                toggle.addEventListener('click', function() {
                    const type = inputElement.getAttribute('type') === 'password' ? 'text' : 'password';
                    inputElement.setAttribute('type', type);
                    this.innerHTML = type === 'password' ? '👁️' : '👁️‍🗨️';
                });
            }

            addPasswordToggle(passwordInput);

            // Автозаполнение никнейма на основе имени пользователя
            const nicknameInput = document.querySelector('input[name="Nickname"]');
            usernameInput.addEventListener('blur', function() {
                if (nicknameInput.value === '' && this.value.trim() !== '') {
                    nicknameInput.value = this.value.trim();
                }
            });

            // Валидация формы перед отправкой
            form.addEventListener('submit', function(e) {
                let isValid = true;
                const errors = [];

                // Проверка имени пользователя
                const username = usernameInput.value.trim();
                if (username.length < 3) {
                    isValid = false;
                    usernameInput.classList.add('is-invalid');
                    errors.push('Имя пользователя должно содержать минимум 3 символа');
                } else if (!isValidUsername(username)) {
                    isValid = false;
                    usernameInput.classList.add('is-invalid');
                    errors.push('Имя пользователя может содержать только буквы английского алфавита и символ подчеркивания');
                } else {
                    usernameInput.classList.remove('is-invalid');
                }

                // Проверка пароля
                if (passwordInput.value.length < 6) {
                    isValid = false;
                    passwordInput.classList.add('is-invalid');
                    errors.push('Пароль должен содержать минимум 6 символов');
                } else {
                    passwordInput.classList.remove('is-invalid');
                }

                // Проверка роли
                if (!roleSelect.value) {
                    isValid = false;
                    roleSelect.classList.add('is-invalid');
                    errors.push('Выберите роль');
                } else {
                    roleSelect.classList.remove('is-invalid');
                }

                if (!isValid) {
                    e.preventDefault();
                    alert('Ошибки валидации:\n- ' + errors.join('\n- '));
                }
            });

            // Снятие отметки об ошибке при вводе
            usernameInput.addEventListener('input', function() {
                if (this.value.trim().length >= 3 && isValidUsername(this.value)) {
                    this.classList.remove('is-invalid');
                }
            });

            passwordInput.addEventListener('input', function() {
                if (this.value.length >= 6) {
                    this.classList.remove('is-invalid');
                }
            });

            roleSelect.addEventListener('change', function() {
                if (this.value) {
                    this.classList.remove('is-invalid');
                }
            });
        });
    </script>
}