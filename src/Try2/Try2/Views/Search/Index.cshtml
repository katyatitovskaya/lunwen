@{
    ViewData["Title"] = "Поиск";
}

<div class="search-container">
    <h2>Поиск</h2>

    <div class="search-controls">
        <div class="search-row">
            <!-- Поле поиска по тексту -->
            <div class="search-input-wrapper">
                <input type="text"
                       id="searchQuery"
                       class="search-input"
                       placeholder="Поиск по тексту..."
                       autocomplete="off" />
            </div>

            <!-- ОБЪЕДИНЕННОЕ ПОЛЕ: поиск тега + отображение выбранного -->
            <div class="tag-input-wrapper">
                <input type="text"
                       id="tagSearchInput"
                       class="search-input"
                       placeholder="Поиск тега..."
                       autocomplete="off" />
                <div id="tagSuggestions" class="tag-suggestions-dropdown"></div>
            </div>

            <!-- Тип поиска -->
            <select id="searchType" class="search-select">
                <option value="All">Все</option>
                <option value="Posts">Посты</option>
                <option value="Users">Люди</option>
            </select>

            <!-- Фильтр фазы -->
            <select id="phaseFilter" class="search-select" disabled>
                <option value="">Все фазы</option>
                <option value="0">📚 Интересуюсь</option>
                <option value="1">🎓 Изучаю</option>
                <option value="2">👨‍🏫 Преподаю</option>
            </select>
        </div>
    </div>

    <hr />

    <div id="searchResults">
        <div class="text-center text-muted py-5">
            Введите запрос или выберите тег для поиска
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            let selectedTagId = null;
            let selectedTagName = null;
            let searchTimeout;
            let tagSearchTimeout;
            let currentSearchType = 'All';

            const searchQuery = document.getElementById('searchQuery');
            const tagSearchInput = document.getElementById('tagSearchInput');
            const searchType = document.getElementById('searchType');
            const phaseFilter = document.getElementById('phaseFilter');
            const tagSuggestions = document.getElementById('tagSuggestions');
            const resultsDiv = document.getElementById('searchResults');

            // Управление видимостью фильтра фазы
            function updatePhaseFilterVisibility() {
                if (currentSearchType === 'Posts') {
                    phaseFilter.disabled = true;
                    phaseFilter.value = '';
                } else {
                    phaseFilter.disabled = false;
                }
            }

            searchType.addEventListener('change', function() {
                currentSearchType = this.value;
                updatePhaseFilterVisibility();
                performSearch();
            });

            updatePhaseFilterVisibility();
            phaseFilter.addEventListener('change', performSearch);

            // Живой поиск по тексту
            searchQuery.addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(performSearch, 300);
            });

            // Поиск тегов при вводе
            tagSearchInput.addEventListener('input', function() {
                clearTimeout(tagSearchTimeout);
                const term = this.value.trim();

                if (term.length < 1) {
                    tagSuggestions.style.display = 'none';
                    return;
                }

                tagSearchTimeout = setTimeout(function() { searchTags(term); }, 300);
            });

            // Закрытие подсказок при клике вне
            document.addEventListener('click', function(e) {
                if (!tagSearchInput.contains(e.target) && !tagSuggestions.contains(e.target)) {
                    tagSuggestions.style.display = 'none';
                }
            });

            // Очистка выбранного тега при ручном вводе
            tagSearchInput.addEventListener('input', function() {
                if (selectedTagId) {
                    selectedTagId = null;
                    selectedTagName = null;
                }
            });

            async function searchTags(term) {
                try {
                    console.log('Поиск тегов:', term);
                    const response = await fetch('/api/searchapi/tags?term=' + encodeURIComponent(term));
                    const tags = await response.json();
                    console.log('Найдено тегов:', tags.length);
                    if (tags.length > 0) {
                        displayTagSuggestions(tags);
                    } else {
                        tagSuggestions.style.display = 'none';
                    }
                } catch (error) {
                    console.error('Ошибка поиска тегов:', error);
                }
            }

            function displayTagSuggestions(tags) {
                let html = '';
                tags.forEach(function(tag) {
                    html += '<div class="tag-suggestion-item" onclick="selectTag(' + tag.id + ', \'' + tag.name.replace(/'/g, "\\'") + '\')">' +
                        '<span>' + tag.name + '</span>' +
                        '<span style="color:#6c757d;font-size:0.85em;">' + tag.usageCount + ' исп.</span>' +
                    '</div>';
                });
                tagSuggestions.innerHTML = html;
                tagSuggestions.style.display = 'block';
            }

            window.selectTag = function(tagId, tagName) {
                console.log('Выбран тег:', tagId, tagName);
                selectedTagId = tagId;
                selectedTagName = tagName;
                tagSearchInput.value = tagName; // Показываем выбранный тег в поле
                tagSuggestions.style.display = 'none';
                performSearch(); // Сразу ищем
            };

            async function performSearch() {
                const query = searchQuery.value.trim();

                // Формируем параметры
                let params = 'query=' + encodeURIComponent(query) +
                             '&searchType=' + currentSearchType;

                if (currentSearchType !== 'Posts') {
                    params += '&phase=' + (phaseFilter.value || '');
                }

                // Добавляем tagId если тег выбран (из selectedTagId, а не из поля)
                if (selectedTagId) {
                    params += '&tagId=' + selectedTagId;
                }

                console.log('Параметры поиска:', params);

                // Не ищем если нет ни запроса, ни тега
                if (!query && !selectedTagId) {
                    resultsDiv.innerHTML = '<div class="text-center text-muted py-5">Введите запрос или выберите тег для поиска</div>';
                    return;
                }

                resultsDiv.innerHTML = '<div class="text-center py-5"><div class="spinner-border"></div></div>';

                try {
                    const response = await fetch('/api/searchapi?' + params);
                    const data = await response.json();
                    console.log('Результаты поиска:', data);
                    displayResults(data);
                } catch (error) {
                    console.error('Ошибка поиска:', error);
                    resultsDiv.innerHTML = '<div class="alert alert-danger">Ошибка при выполнении поиска</div>';
                }
            }

            function displayResults(data) {
                let html = '';

                // Пользователи
                    if (data.users && data.users.length > 0) 
                    {
                html += '<div class="users-results">';
                html += '<div class="section-title">Пользователи (' + data.users.length + ')</div>';

                data.users.forEach(function(user) {
                    html += '<div class="user-card">';

                // Аватарка с ссылкой на профиль
                html += '<a href="/User/Profile/' + user.id + '" style="display: contents;">';
                if (user.profilePhotoPath) {
                    html += '<img src="' + user.profilePhotoPath + '" class="user-avatar-img" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-right: 15px;" alt="' + user.nickname + '" />';
                } else {
                    html += '<div class="user-avatar" style="width: 50px; height: 50px; border-radius: 50%; margin-right: 15px; background: #FFE0B2; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #E65100;">' + user.nickname.charAt(0).toUpperCase() + '</div>';
                }
                html += '</a>';

                // Информация о пользователе
                html += '<div class="user-info">';

                // Никнейм - ссылка на профиль
                html += '<div class="nickname" style="color: #E65100; font-size: 1.1rem; font-weight: 600;">';
                html += '<a href="/User/Profile/' + user.id + '" style="color: #E65100; text-decoration: none;">' + user.nickname + '</a>';
                html += '</div>';

                // Юзернейм - ссылка на профиль
                html += '<div class="username" style="color: #4CAF50; font-size: 0.9rem; margin-bottom: 5px;">';
                html += '<a href="/User/Profile/' + user.id + '" style="color: #4CAF50; text-decoration: none;">@@' + user.username + '</a>';
                html += '</div>';

                // Теги пользователя
                if (user.tags && user.tags.length > 0) {
                    html += '<div class="user-tags-profile" style="margin: 5px 0;">';

                    // Группируем теги по фазам
                    var interestedTags = user.tags.filter(function(t) { return t.phase === 0; });
                    var studyingTags = user.tags.filter(function(t) { return t.phase === 1; });
                    var teachingTags = user.tags.filter(function(t) { return t.phase === 2; });

                    // Интересуюсь
                    if (interestedTags.length > 0) {
                        html += '<div class="tag-phase-group" style="margin-bottom: 3px;">';
                        html += '<span class="phase-label" style="font-weight: 600; color: #E65100; margin-right: 5px; font-size: 0.85rem;">Интересуюсь: </span>';
                        html += '<div class="phase-tags" style="display: inline-flex; flex-wrap: wrap; gap: 4px;">';
                        interestedTags.forEach(function(t) {
                            html += '<span class="profile-tag" style="display: inline-flex; align-items: center; background: #FFF8E1; padding: 2px 8px; border-radius: 20px; font-size: 0.8rem; color: #1B5E20; gap: 2px; border: 1px solid #1B5E20;">';
                            html += t.tagName;
                            html += '<span class="tag-year" style="color: #888; font-size: 0.7rem; margin-left: 2px;">с ' + t.studyStartYear + '</span>';
                            html += '</span>';
                        });
                        html += '</div></div>';
                    }

                    // Изучаю
                    if (studyingTags.length > 0) {
                        html += '<div class="tag-phase-group" style="margin-bottom: 3px;">';
                        html += '<span class="phase-label" style="font-weight: 600; color: #E65100; margin-right: 5px; font-size: 0.85rem;">Изучаю: </span>';
                        html += '<div class="phase-tags" style="display: inline-flex; flex-wrap: wrap; gap: 4px;">';
                        studyingTags.forEach(function(t) {
                            html += '<span class="profile-tag" style="display: inline-flex; align-items: center; background: #FFF8E1; padding: 2px 8px; border-radius: 20px; font-size: 0.8rem; color: #1B5E20; gap: 2px; border: 1px solid #1B5E20;">';
                            html += t.tagName;
                            html += '<span class="tag-year" style="color: #888; font-size: 0.7rem; margin-left: 2px;">с ' + t.studyStartYear + '</span>';
                            if (!t.isConfirmed) {
                                html += '<span class="pending-badge" title="Ожидает подтверждения" style="margin-left: 2px; font-size: 11px;">⏳</span>';
                            }
                            html += '</span>';
                        });
                        html += '</div></div>';
                    }

                    // Преподаю
                    if (teachingTags.length > 0) {
                        html += '<div class="tag-phase-group" style="margin-bottom: 3px;">';
                        html += '<span class="phase-label" style="font-weight: 600; color: #E65100; margin-right: 5px; font-size: 0.85rem;">Преподаю: </span>';
                        html += '<div class="phase-tags" style="display: inline-flex; flex-wrap: wrap; gap: 4px;">';
                        teachingTags.forEach(function(t) {
                            html += '<span class="profile-tag" style="display: inline-flex; align-items: center; background: #FFF8E1; padding: 2px 8px; border-radius: 20px; font-size: 0.8rem; color: #1B5E20; gap: 2px; border: 1px solid #1B5E20;">';
                            html += t.tagName;
                            html += '<span class="tag-year" style="color: #888; font-size: 0.7rem; margin-left: 2px;">с ' + t.studyStartYear + '</span>';
                            if (!t.isConfirmed) {
                                html += '<span class="pending-badge" title="Ожидает подтверждения" style="margin-left: 2px; font-size: 11px;">⏳</span>';
                            }
                            html += '</span>';
                        });
                        html += '</div></div>';
                    }

                    html += '</div>';
                }

                html += '</div>'; // конец user-info

                // Кнопка подписки
                html += '<div>';
                html += '<button class="btn follow-btn ' + (user.isFollowedByCurrentUser ? 'btn-outline-secondary' : 'btn-primary') + '" ';
                html += 'onclick="toggleFollow(' + user.id + ', this)" style="padding: 6px 16px; font-size: 0.85rem;">';
                html += (user.isFollowedByCurrentUser ? 'Отписаться' : 'Подписаться');
                html += '</button>';
                html += '</div>';

                html += '</div>'; // конец user-card
            });

            html += '</div>';
        }

                 // Посты
        if (data.posts && data.posts.length > 0) {
            html += '<div class="posts-results">';
            html += '<div class="section-title">Посты (' + data.posts.length + ')</div>';

            data.posts.forEach(function(post) {
                html += '<div class="post-card">';

                // Информация об авторе - ссылка на профиль
                html += '<a href="/User/Profile/' + post.authorId + '" class="post-author-link">';
                html += '<div class="post-header">';

                // Фото пользователя
                if (post.authorProfilePhoto) {
                    html += '<img src="' + post.authorProfilePhoto + '" alt="Profile photo" style="width:40px; height:40px; border-radius:50%; object-fit:cover;" />';
                } else {
                    html += '<div style="width:40px; height:40px; border-radius:50%; background-color:#e0e0e0; display:flex; align-items:center; justify-content:center; font-size:20px; color:#666;">';
                    html += (post.authorNickname ? post.authorNickname.charAt(0).toUpperCase() : '?');
                    html += '</div>';
                }

                // Информация об авторе
                html += '<div>';
                html += '<strong class="post-author">' + escapeHtml(post.authorNickname) + '</strong>';
                html += '<span class="username" style="display: block;">@@' + escapeHtml(post.authorUsername) + '</span>';
                html += '</div>';

                html += '</div>';
                html += '</a>';

                html += '<a href="/Posts/Details/' + post.id + '" class="post-text-link" style="text-decoration: none; color: inherit;">';
                html += '<div class="post-text">';
                html += '<p>' + formatPostText(post.text) + '</p>';
                html += '</div>';
                html += '</a>';

                // Теги поста
                if (post.tags && post.tags.length > 0) {
                    html += '<div class="post-tags-container" style="margin-bottom: 8px; display: flex; flex-wrap: wrap; gap: 5px;">';
                    post.tags.forEach(function(t) {
                        html += '<span class="post-tag-item" style="background: #f0f0f0; padding: 3px 10px; border-radius: 15px; font-size: 0.8rem; color: #555;">';
                        html += '#' + escapeHtml(t.tagName);
                        html += '</span>';
                    });
                    html += '</div>';
                }

                // Футер поста
                html += '<div class="post-footer">';
                html += '<span class="likes">❤️ ' + post.likesCount + '</span>';
                html += '<span class="date">' + new Date(post.publicationDate).toLocaleDateString() + '</span>';
                html += '</div>';

                html += '</div>'; // конец post-card
            });

            html += '</div>';
        }

                if ((!data.users || data.users.length === 0) && (!data.posts || data.posts.length === 0)) {
                    html = '<div class="text-center text-muted py-5">Ничего не найдено</div>';
                }

                resultsDiv.innerHTML = html;
            }

            function getPhaseShort(phase) {
                const phases = ['📚', '🎓', '👨‍🏫'];
                return phases[phase] || '';
            }

            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            window.toggleFollow = async function(userId, btn) {
                const isFollowed = btn.textContent.includes('Отписаться');
                const url = isFollowed ? '/User/Unfollow' : '/User/Follow';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': token
                        },
                        body: 'userId=' + userId
                    });

                    if (response.ok) {
                        btn.textContent = isFollowed ? 'Подписаться' : 'Отписаться';
                        btn.classList.toggle('btn-primary');
                        btn.classList.toggle('btn-outline-secondary');
                    }
                } catch (error) {
                    console.error('Ошибка:', error);
                }
            };
        });

                function formatPostText(text) {
            if (!text) return '';

            // Экранируем HTML
            let formatted = escapeHtml(text);

            // Жирный текст **текст**
            formatted = formatted.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

            // Курсив *текст*
            formatted = formatted.replace(/\*(.*?)\*/g, '<em>$1</em>');

            // Зачеркнутый ~~текст~~
            formatted = formatted.replace(/~~(.*?)~~/g, '<del>$1</del>');

            // Размер текста [large]текст[/large]
            formatted = formatted.replace(/\[large\](.*?)\[\/large\]/g, '<span style="font-size: 1.5em;">$1</span>');
            formatted = formatted.replace(/\[medium\](.*?)\[\/medium\]/g, '<span style="font-size: 1.2em;">$1</span>');
            formatted = formatted.replace(/\[small\](.*?)\[\/small\]/g, '<span style="font-size: 0.9em;">$1</span>');

            // Цвета [red]текст[/red]
            formatted = formatted.replace(/\[red\](.*?)\[\/red\]/g, '<span style="color: #8B0000;">$1</span>');
            formatted = formatted.replace(/\[green\](.*?)\[\/green\]/g, '<span style="color: #1B5E20;">$1</span>');
            formatted = formatted.replace(/\[blue\](.*?)\[\/blue\]/g, '<span style="color: #00008B;">$1</span>');
            formatted = formatted.replace(/\[orange\](.*?)\[\/orange\]/g, '<span style="color: #FF4500;">$1</span>');
            formatted = formatted.replace(/\[pink\](.*?)\[\/pink\]/g, '<span style="color: #FF1493;">$1</span>');

            // Маркированный список
            formatted = formatted.replace(/^- (.*?)$/gm, '<li style="margin-left: 20px;">$1</li>');
            formatted = formatted.replace(/(<li.*?<\/li>)/gs, '<ul>$1</ul>');

            // Переносы строк
            formatted = formatted.replace(/\n/g, '<br>');

            return formatted;
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
}

